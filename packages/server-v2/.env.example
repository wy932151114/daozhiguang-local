# ========================================
# DZS-OS V2 Server Configuration
# ========================================

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/dzs-os-v2

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=dzs-os-v2-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# SMTP (Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
EMAIL_FROM=noreply@dzs-os.com

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
