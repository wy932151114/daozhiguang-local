{
  "moduleFileExtensions": ["ts", "js", "json"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^@common/(.*)$": "<rootDir>/src/common/$1",
    "^@modules/(.*)$": "<rootDir>/src/modules/$1",
    "^@database/(.*)$": "<rootDir>/src/database/$1",
    "^@events/(.*)$": "<rootDir>/src/events/$1"
  }
}
